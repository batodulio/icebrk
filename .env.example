# Copy to .env.local (gitignored) and fill in from the Supabase dashboard:
# Project Settings → API, project "icebrk".
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Also required: Authentication → Providers → Email → turn OFF "Confirm email".
# IceBrk signup never collects a real email (see src/lib/username.ts), so a
# confirmation link would be sent to an address nobody can read.
